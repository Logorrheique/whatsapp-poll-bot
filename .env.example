# ============================================================
# Configuration Poll Bot — copier en .env et remplir
# ============================================================

# --- OBLIGATOIRES ---

# Numéros admin (sans +, séparés par virgules, format international)
# Les admins peuvent : gérer whitelist, observateurs, lier/délier WhatsApp
ADMIN_PHONES=33612345678,33698765432

# Secret pour afficher le QR de pairing WhatsApp (>= 24 chars random)
# Génère-en un avec : openssl rand -hex 24
PAIR_SECRET=changeme_generer_un_vrai_secret

# --- OPTIONNELLES ---

# URL PostgreSQL pour les backups (si non défini, backups désactivés)
# Sur Railway : auto-injectée si tu attaches un service Postgres
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Whitelist de numéros autorisés à se connecter au dashboard
# Si vide, tout numéro listé dans ADMIN_PHONES ou VIEWER_PHONES peut entrer
# L'UI ne permet QUE le retrait — l'ajout passe forcément par cette variable
ALLOWED_PHONES=

# Numéros observateurs (lecture seule)
VIEWER_PHONES=

# Port HTTP (défaut 3000)
PORT=3000

# Production : active CORS strict + redirect HTTPS
# NODE_ENV=production

# Timezone des crons (défaut Europe/Paris)
# TIMEZONE=Europe/Paris

# Secret pour le webhook de backup externe (POST /api/backup-trigger/*)
# BACKUP_TRIGGER_SECRET=

# Niveau de log Baileys : warn (défaut), info, debug, trace
# BAILEYS_LOG_LEVEL=warn

# ============================================================
# Poll Bot configuration — copy to .env and fill in
# ============================================================

# --- REQUIRED ---

# Admin phone numbers (no +, comma-separated, international format)
# Admins can: manage whitelist, viewers, link/unlink WhatsApp
ADMIN_PHONES=33612345678,33698765432

# Secret used to reveal the WhatsApp pairing QR (>= 24 random chars)
# Generate with: openssl rand -hex 24
PAIR_SECRET=changeme_generate_a_real_secret

# --- OPTIONAL ---

# PostgreSQL URL for backups (if unset, backups are disabled)
# On Railway: auto-injected when you attach a Postgres service
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Whitelist of phone numbers allowed to sign in to the dashboard
# If empty, any number in ADMIN_PHONES or VIEWER_PHONES can sign in
# The UI ONLY allows removal — additions must come from this variable
ALLOWED_PHONES=

# Viewer phone numbers (read-only access)
VIEWER_PHONES=

# HTTP port (default 3000)
PORT=3000

# Production: enables strict CORS + HTTPS redirect
# NODE_ENV=production

# Cron timezone (default Europe/Paris)
# TIMEZONE=Europe/Paris

# Secret for the external backup webhook (POST /api/backup-trigger/*)
# BACKUP_TRIGGER_SECRET=

# Baileys log level: warn (default), info, debug, trace
# BAILEYS_LOG_LEVEL=warn
